# Obsidian vault
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Vector store backend: "pgvector" (vectors in PostgreSQL) or "qdrant" (dedicated vector DB)
VECTOR_BACKEND=pgvector
COLLECTION_NAME=obsidian

# Qdrant (only needed when VECTOR_BACKEND=qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=change-me-to-a-strong-secret

# Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...

# PostgreSQL (DSN is built from these — or set POSTGRES_DSN directly to override)
POSTGRES_USER=mnemolith
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=mnemolith
POSTGRES_PORT=5435
